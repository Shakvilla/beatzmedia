{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(*)", "Edit(*)", "Write(*)", "Glob(*)", "Grep(*)",
      "Bash(./backend/mvnw *)", "Bash(./mvnw *)", "Bash(mvn *)",
      "Bash(bash backend/scripts/*)", "Bash(backend/scripts/*)",
      "Bash(git status*)", "Bash(git add *)", "Bash(git commit *)",
      "Bash(git checkout *)", "Bash(git switch *)", "Bash(git branch *)",
      "Bash(git fetch *)", "Bash(git pull *)", "Bash(git push origin *)",
      "Bash(git diff*)", "Bash(git log*)", "Bash(git rev-parse*)", "Bash(git merge *)",
      "Bash(gh pr *)", "Bash(gh issue *)", "Bash(gh run *)", "Bash(gh release *)", "Bash(gh api *)",
      "Bash(docker compose *)", "Bash(docker ps*)", "Bash(docker logs *)",
      "Bash(curl *)", "Bash(ls *)", "Bash(cat *)", "Bash(mkdir *)", "Bash(cp *)", "Bash(mv *)",
      "Bash(echo *)", "Bash(grep *)", "Bash(rg *)", "Bash(find *)", "Bash(sed *)", "Bash(awk *)",
      "Bash(jq *)", "Bash(yq *)", "Bash(test *)", "Bash(java *)"
    ],
    "deny": [
      "Bash(git push --force*)", "Bash(git push -f*)", "Bash(git push * --force*)",
      "Bash(rm -rf /*)", "Bash(rm -rf ~*)", "Bash(sudo *)",
      "Read(./**/.env)", "Read(./**/*.pem)", "Read(./**/secrets/**)"
    ],
    "ask": [
      "Bash(git push origin main*)", "Bash(gh release create*)", "Bash(docker push *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"" }
    ],
    "PreToolUse": [
      { "matcher": "Bash", "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh\"" }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write", "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-java.sh\"" }
    ]
  }
}
