{
  "info": {
    "name": "BeatzClik Media API \u2014 1.0.0",
    "description": "BeatzClik buy-to-own music streaming & marketplace API\n\nGenerated from /q/openapi. Base URL defaults to the local Docker stack on :8081. Run **Signup** or **Login** first \u2014 the JWT is captured into {{token}} automatically and reused by all authed requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "artistId",
      "value": "black-sherif",
      "type": "string"
    },
    {
      "key": "albumId",
      "value": "iron-boy",
      "type": "string"
    },
    {
      "key": "trackId",
      "value": "last-last",
      "type": "string"
    },
    {
      "key": "playlistId",
      "value": "vibes-from-the-233",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Identity \u2014 Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ama+test@beatzclik.local\",\n  \"password\": \"Passw0rd!23\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Capture the JWT into the collection {{token}} variable for authed requests.",
                  "try {",
                  "  const b = pm.response.json();",
                  "  if (b && b.token) {",
                  "    pm.collectionVariables.set('token', b.token);",
                  "    console.log('Saved token to {{token}}');",
                  "  }",
                  "} catch (e) { /* non-JSON response */ }",
                  "pm.test('status is 2xx', () => pm.expect(pm.response.code).to.be.within(200, 299));"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "auth",
                "logout"
              ]
            },
            "description": "Logout"
          },
          "response": []
        },
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "auth",
                "signup"
              ]
            },
            "description": "Signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ama Mensah\",\n  \"email\": \"ama+test@beatzclik.local\",\n  \"password\": \"Passw0rd!23\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Capture the JWT into the collection {{token}} variable for authed requests.",
                  "try {",
                  "  const b = pm.response.json();",
                  "  if (b && b.token) {",
                  "    pm.collectionVariables.set('token', b.token);",
                  "    console.log('Saved token to {{token}}');",
                  "  }",
                  "} catch (e) { /* non-JSON response */ }",
                  "pm.test('status is 2xx', () => pm.expect(pm.response.code).to.be.within(200, 299));"
                ]
              }
            }
          ]
        }
      ]
